<title>Bhuvnesh Pattnaik — Resume</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
/* ── Reset ───────────────────────────────────────── */
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --dark:#1E2330;
  --darker:#161920;
  --teal:#4EC9B0;
  --blue:#9CDCFE;
  --yellow:#DCDCAA;
  --white:#FFFFFF;
  --muted:#8A9BB0;
  --body:#2C3E50;
  --mid:#546E7A;
  --divider:#DEE4EA;
  --sidebar-w:230px;
}

/* ── Layout ──────────────────────────────────────── */
html,body{background:#f0f2f5;font-family:'Outfit',sans-serif;}

.page{
  width:210mm;
  min-height:297mm;
  margin:0 auto;
  display:flex;
  background:#fff;
  position:relative;
  page-break-after:always;
}
.page:last-child{page-break-after:auto;}

/* ── Sidebar ─────────────────────────────────────── */
.sidebar{
  width:var(--sidebar-w);
  min-height:100%;
  background:var(--dark);
  flex-shrink:0;
  padding:20px 18px 20px 18px;
  display:flex;
  flex-direction:column;
}

.name-block{margin-bottom:10px;}
.name-first{font-family:'JetBrains Mono',monospace;font-size:28px;font-weight:700;color:var(--teal);line-height:1.1;}
.name-last{font-family:'JetBrains Mono',monospace;font-size:28px;font-weight:700;color:var(--white);line-height:1.1;margin-bottom:6px;}
.name-title{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);line-height:1.5;}

.s-section{margin-top:11px;}
.s-heading{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;font-weight:700;
  color:var(--teal);letter-spacing:1.5px;
  text-transform:uppercase;
  border-bottom:1.5px solid var(--teal);
  padding-bottom:4px;margin-bottom:8px;
}

.s-item{
  font-family:'JetBrains Mono',monospace;
  font-size:9.5px;color:var(--muted);
  margin-bottom:3px;line-height:1.4;
  display:flex;align-items:flex-start;gap:5px;
}
.s-item .arrow{color:var(--teal);flex-shrink:0;}
.s-item .star{color:var(--yellow);flex-shrink:0;}
.s-item .dot{color:var(--teal);flex-shrink:0;}

.s-skill{
  font-family:'JetBrains Mono',monospace;
  font-size:9.5px;color:var(--blue);
  margin-bottom:4px;line-height:1.4;
}
.s-skill.yellow{color:var(--yellow);}

.s-badge{
  display:inline-block;
  background:#0D1A26;
  border:1px solid #2A4A5A;
  color:var(--blue);
  font-family:'JetBrains Mono',monospace;
  font-size:8px;padding:2px 6px;
  border-radius:2px;margin:2px 2px 2px 0;
}

.stat-row{display:flex;align-items:baseline;gap:4px;margin-bottom:4px;}
.stat-val{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:700;color:var(--teal);}
.stat-label{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--muted);line-height:1.3;}

.bar-row{margin-bottom:3px;}
.bar-label{font-family:'JetBrains Mono',monospace;font-size:8.5px;color:var(--muted);margin-bottom:2px;display:flex;justify-content:space-between;}
.bar-track{background:#0D1A26;border-radius:1px;height:3px;overflow:hidden;}
.bar-fill{height:100%;background:var(--teal);border-radius:1px;}

/* ── Main ────────────────────────────────────────── */
.main{
  flex:1;
  padding:28px 28px 28px 26px;
  min-height:100%;
}

.m-section{margin-bottom:20px;}
.m-heading{
  font-family:'JetBrains Mono',monospace;
  font-size:11px;font-weight:700;
  color:var(--body);letter-spacing:1.5px;
  text-transform:uppercase;
  border-bottom:1.5px solid var(--divider);
  padding-bottom:5px;margin-bottom:12px;
  display:flex;align-items:center;gap:6px;
}
.m-heading .slash{color:var(--teal);}

.profile-text{
  font-size:10.5px;line-height:1.75;
  color:var(--body);margin-bottom:10px;
}

.metrics{display:flex;gap:0;margin-bottom:4px;}
.metric{
  flex:1;text-align:center;
  border-right:1px solid var(--divider);
  padding:6px 4px;
}
.metric:last-child{border-right:none;}
.metric-val{font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:700;color:var(--teal);}
.metric-label{font-family:'JetBrains Mono',monospace;font-size:7.5px;color:var(--mid);margin-top:1px;}

/* Experience */
.exp-block{margin-bottom:14px;padding-bottom:12px;border-bottom:1px dashed #e8ecf0;}
.exp-block:last-child{border-bottom:none;margin-bottom:0;}

.exp-title{
  font-family:'JetBrains Mono',monospace;
  font-size:12px;font-weight:700;color:var(--body);
  margin-bottom:2px;
}
.exp-meta{
  display:flex;align-items:center;gap:6px;
  margin-bottom:5px;flex-wrap:wrap;
}
.exp-company{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--teal);}
.exp-sep{color:var(--divider);font-size:10px;}
.exp-period{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--mid);font-style:italic;}
.exp-loc{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--mid);font-style:italic;}
.exp-desc{font-size:9.5px;color:var(--mid);font-style:italic;margin-bottom:5px;line-height:1.5;}

.exp-bullets{list-style:none;margin-bottom:6px;}
.exp-bullets li{
  font-size:9.8px;color:var(--body);line-height:1.55;
  padding-left:14px;position:relative;margin-bottom:3px;
}
.exp-bullets li::before{
  content:'▸';color:var(--teal);
  position:absolute;left:0;font-size:9px;
}
.exp-bullets li strong{font-weight:600;}

.stack-line{
  font-family:'JetBrains Mono',monospace;
  font-size:8.5px;color:var(--mid);
  margin-top:4px;
}
.stack-line span{color:var(--teal);}

/* Projects */
.proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.proj-card{border:1px solid var(--divider);border-radius:3px;padding:8px 10px;}
.proj-name{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--teal);margin-bottom:2px;}
.proj-meta-line{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--mid);margin-bottom:4px;}
.proj-desc{font-size:9px;color:var(--body);line-height:1.5;}

/* ── PRINT ───────────────────────────────────────── */
@media print{
  html,body{background:#fff;margin:0;padding:0;}
  .page{
    width:210mm;height:297mm;
    margin:0;box-shadow:none;
    page-break-after:always;
    overflow:hidden;
  }
  .page:last-child{page-break-after:auto;}
  .sidebar{min-height:297mm;}
  @page{margin:0;size:A4;}
}

/* Screen only extras */
@media screen{
  .page{box-shadow:0 4px 40px rgba(0,0,0,0.15);margin:20px auto;}
}
</style>
